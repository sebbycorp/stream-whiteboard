{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stream Whiteboard",
  "version": "0.1.0",
  "identifier": "io.solo.streamwhiteboard",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Stream Whiteboard",
        "width": 1000,
        "height": 1200,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.icns"]
  }
}
